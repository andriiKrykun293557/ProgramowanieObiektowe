class ListaObecnosci
{
    bool klasa_tab_obecnosc[10];
    Osoba klasa_tab_osob[10];

    int znajdzPusteMiejsce()
    {
        for(int i=0;klasa_tab_osob[i].getNazwisko()==""; i++) 
        {
            return i;
        }
        return -1;
    }

    int znajdzOsobe(string nazwisko)
    {
        for (int i=0; klasa_tab_osob[i].getNazwisko()==nazwisko;i++) 
        {
            return i;
        }
        return -1;
    }

public:
    void dodajOsobe(Osoba nowa_osoba)
    {
        int i=znajdzPusteMiejsce();
        if (i!=-1) klasa_tab_osob[i]=nowa_osoba;
    }

    void drukujListe()
    {
        for (int i=0;klasa_tab_osob[i].getNazwisko()!=""; i++)
        {
            cout<<"Nr ideksu: "<<klasa_tab_osob[i].getIndeks()<<" Imie: "<<klasa_tab_osob[i].getImie()<<" Nazwisko: "<<klasa_tab_osob[i].getNazwisko()<<" obecnosc: "<<klasa_tab_obecnosc[i]<<endl;
        }
    }

    void ustawObecnosc(string nazwisko, bool nowa_obecnosc) 
    {
        int i=znajdzOsobe(nazwisko);
        if (i!=-1) 
        {
            int j=znajdzPusteMiejsce();
            klasa_tab_osob[j]=klasa_tab_osob[i];
            klasa_tab_obecnosc[j]=nowa_obecnosc;
            cout<<"Obecnosc ustawiona"<<endl;
        }
    }
};

class UiUzyt {
    Osoba *klasa_tablica_osob;
    ListaObecnosci *klasa_tablica_list;
    int klasa_ile_osob, klasa_ile_list;
    int klasa_wybor;

    int znajdzPuste()
    {
        for (int i=0; i<klasa_ile_osob; i++)
        {
            if (klasa_tablica_osob[i].getNazwisko().empty())
            {
                return i;
            }
        }
        return -1;
    }

    int znajdzNazwisko(string nazwisko)
    {
        for (int i=0; i<klasa_ile_osob;i++)
        {
            if (klasa_tablica_osob[i].getNazwisko()==nazwisko)
            {
                return i;
            }
        }
        return -1;
    }

    void utworzOsobe()
    {
        int indeks;
        string imie;
        string nazwisko;
        Osoba nowa_osoba;

        cout<<"Podaj indeks: "<<endl;
        cin>>indeks;
        nowa_osoba.setIndeks(indeks);

        cout<<"Podaj imie: "<<endl;
        cin>>imie;
        nowa_osoba.setImie(imie);

        cout<<"Podaj nazwisko: "<<endl;
        cin>>nazwisko;
        nowa_osoba.setNazwisko(nazwisko);

        int i=znajdzPuste();
        if (i!=-1) klasa_tablica_osob[i]=nowa_osoba;
    }

    void dodajOsobe()
    {
        string nazwisko;
        int lista;
        
        cout<<"Nazwisko osoby: "<<endl;
        cin>>nazwisko;

        cout<<"wybierz liste: "<<endl;
        cin>>lista;
        
        int i=znajdzNazwisko(nazwisko);
        if(i!=-1) klasa_tablica_list[lista].dodajOsobe(klasa_tablica_osob[i]);
    }

    void ustawObecnosc()
    {
        string nazwisko;
        int lista;
        bool obecnosc;

        cout<<"Podaj nazwisko osoby: "<<endl;
        cin>>nazwisko;

        cout<<"podaj liste: "<<endl;
        cin>>lista;

        cout<<"podaj obecnosc: "<<endl;
        cin>>obecnosc;

        klasa_tablica_list[lista].ustawObecnosc(nazwisko, obecnosc);
    }

    void przesun(int index)
    {
        for (int i=index; i<klasa_ile_osob-1; i++)
        {
            klasa_tablica_osob[i].setIndeks(klasa_tablica_osob[i+1].getIndeks());
            klasa_tablica_osob[i].setNazwisko(klasa_tablica_osob[i+1].getNazwisko());
            klasa_tablica_osob[i].setImie(klasa_tablica_osob[i+1].getImie());
        }
        klasa_tablica_osob[klasa_ile_osob-1].setIndeks(0);
        klasa_tablica_osob[klasa_ile_osob-1].setNazwisko("");
        klasa_tablica_osob[klasa_ile_osob-1].setImie("");
    }

    void usunOsobe()
    {
        string nazwisko;
        cout<<"Podaj nazwisko osoby do usuniecia: "<<endl;
        cin>>nazwisko;

        int i=znajdzNazwisko(nazwisko);
        if(i!=-1) przesun(i);
    }

    void edytujOsobe()
    {
        string nazwisko;
        int nowy_indeks;
        string nowe_nazwisko;
        string nowe_imie;

        cout<<"Podaj nazwisko osoby do edycji: "<<endl;
        cin>>nazwisko;
        
        int i=znajdzNazwisko(nazwisko);
        if(i!=-1)
        {
            cout<<"Podaj nowy indeks: "<<endl;
            cin>>nowy_indeks;
            klasa_tablica_osob[i].setIndeks(nowy_indeks);

            cout<<"Podaj nowe imie: "<<endl;
            cin>>nowe_imie;
            klasa_tablica_osob[i].setImie(nowe_imie);

            cout<<"Podaj nowe nazwisko: "<<endl;
            cin>>nowe_nazwisko;
            klasa_tablica_osob[i].setNazwisko(nowe_nazwisko);
        }
    }

    void wyswietlListe() 
    {
        int lista;
        cout<<"Ktora liste chcesz wyswietlic?  "<<endl;
        cin>>lista;

        system("clear");
        klasa_tablica_list[lista].drukujListe();
    }

    void zapiszDoPliku(Osoba os)
    {
        ofstream plik("db.txt", ios::app);

        if(!plik.is_open())
        {
            cout<<"Nie udalo sie otworzyc pliku, sprobuj jeszcze raz"<<endl;
        }

        plik<<os.serialize()<<endl;
        cout<<"Udalo sie zapisac do pliku"<<endl;

        plik.close();
    }

public:
    UiUzyt(Osoba *tabOs, int os, ListaObecnosci *tabLis, int lis)
        : klasa_tablica_osob(tabOs), klasa_ile_osob(os), klasa_tablica_list(tabLis), klasa_ile_list(lis) {}

    void petla() 
    {
        bool menu=true;
        while(menu) 
        {
            cout<<"Witaj w menu!"<<endl;
            cout<<"wybierz co chcesz zrobic: 1 - utwórz osobe, 2 - dodaj osobe do listy, 3 - ustaw obecnosc na liscie, 4 - usun osobe z listy,"<<endl;
            cout<<" 5 - wyswietl listy, 6 - edytuj dane osoby, 7 - zapisz do pliku, 8 - opusc program"<<endl;
            cin>>klasa_wybor;

            system("clear");

            switch(klasa_wybor) {
                case 1: utworzOsobe(); system("clear"); break;
                case 2: dodajOsobe(); system("clear"); break;
                case 3: ustawObecnosc(); system("clear"); break;
                case 4: usunOsobe(); system("clear"); break;
                case 5: wyswietlListe(); break;
                case 6: edytujOsobe(); system("clear"); break;
                case 7: 
                    system("clear");
                    cout<<"co zapisac?"<<endl;
                    cout<<"1 - wszystkie osoby"<<endl;
                    cout<<"2 - Wybrana osobe"<<endl;
                    int zapis_wybor;
                    cin>>zapis_wybor;
                    system("clear");
                    switch(zapis_wybor) 
                    {
                        case 1:
                            for(int i=0; i<klasa_ile_osob; i++)
                            {
                                if(klasa_tablica_osob[i].getNazwisko()!="")
                                {
                                    zapiszDoPliku(klasa_tablica_osob[i]);
                                }
                            }
                            break;
                        case 2:
                        {
                            string nazw;
                            cout<<"Podaj nazwisko osoby, ktora chcesz zapisac: "<<endl;
                            cin>>nazw;
                            int i=znajdzNazwisko(nazw);
                            if(i!=-1)
                            {
                                zapiszDoPliku(klasa_tablica_osob[i]);
                            }
                            break;
                        }
                        default:
                            system("clear");
                            cout<<"Brak takiej opcji"<<endl;
                            break;
                    }
                    break;
                case 8: menu=false; break;
                default: menu=false; break;
            };
        }
    };
};

int main()
{
    Osoba tabOsoba[10];
    ListaObecnosci listaOsob[2];
    UiUzyt ui(tabOsoba, 10, listaOsob, 2);
    
    ui.petla();
    
    return 0;
}
