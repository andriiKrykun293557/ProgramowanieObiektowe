#include <iostream>

using namespace std;

const int N=3;

void dodajOsobe(string *tabNazwisko, string nazwisko, int *tabIndeks, int indeks,
string *tabImie, string imie, int i)
{
    tabNazwisko[i]=nazwisko;
    tabIndeks[i]=indeks;
    tabImie[i]=imie;
}

bool ustawObecnosc(string *tabNazwisko, bool *tabObecnosc, string nazwisko, bool obecnosc)
{
    for(int i=0;i<N;i++)
    {
        if(tabNazwisko[i]==nazwisko)
        {
            tabObecnosc[i]=obecnosc;
        }
    }
    return obecnosc;
}

void drukujListe(string *tabNazwisko,bool *tabObecnosc, int *tabIndeks, string *tabImie)
{
    for (int i=0;i<N;i++)
    {
        cout<<tabIndeks[i]<<" || "<<tabImie[i]<<" || "<<tabNazwisko[i]<<" || "<<tabObecnosc[i]<<endl;
    }
   
}

void edytujOsobe(string *tabNazwisko, int *tabIndeks,
string *tabImie,bool *tabObecnosc, string edytuj)
{
    for(int i=0; i<N; i++)
    {
        if (tabNazwisko[i]==edytuj)
        {
            cout<<"podaj nowe dane: "<<endl;
            
            cout<<"podaj indeks: "<<endl;
            cin>>tabIndeks[i];

            cout<<"podaj imie: "<<endl;
            cin>>tabImie[i];

            cout<<"podaj nazwisko: "<<endl;
            cin>>tabNazwisko[i];

            cout<<"ustaw obecnosc: "<<endl;
            cin>>tabObecnosc[i];
            
            return;
        }
    }
    cout<<"nie znaleziono osoby o takim nazwisku!"<<endl;
}

void usunOsobe(string *tabNazwisko, int *tabIndeks,
string *tabImie,bool *tabObecnosc, string edytuj)
{
    for(int i=0; i<N; i++)
    {
        if (tabNazwisko[i]==edytuj)
        {
                for(int j=i; j<N-1;j++)
                {
                    tabIndeks[j]=tabIndeks[j+1];
                    tabImie[j]=tabImie[j+1];
                    tabNazwisko[j]=tabNazwisko[j+1];
                    tabObecnosc[j]=tabObecnosc[j+1];
                }
                tabIndeks[N-1]=0;
                tabImie[N-1]="";
                tabNazwisko[N-1]="";
                tabObecnosc[N-1]=0;
                return;
                
                cout<<"osoba o nazwisku "<<edytuj<<" zostala usunieta"<<endl;
                return;
        }
    }
}

int main()
{
    int tabIndeks[N]={0};
    int indeks;
   
    string tabImie[N]={" "};
    string imie;
   
    string tabNazwisko[N]={" "};
    string nazwisko;
   
    bool tabObecnosc[N]={0};
    bool obecnosc;
    
    bool menu=true;
    int wybor;
    string edytuj;
    
    cout<<"Witaj w menu!"<<endl;
    
    while(menu)
    {
        cout<<"wybierz co chcesz zrobic: 1 - dodaj osoby i ich obecnosc, 2 - edytuj dane osoby, 3 - usun osobe, 4 - opusc program"<<endl;
        cin>>wybor;
        switch(wybor)
        {
            case 1:
            {
                for (int i=0;i<N;i++)
                {
                    cout<<"wpisujesz osobe nr: "<<i+1<<endl;
                    cout<<"podaj indeks: "<<endl;
                    cin>>indeks;
                    cout<<"podaj imie: "<<endl;
                    cin>>imie;
                    cout<<"podaj nazwisko: "<<endl;
                    cin>>nazwisko;
                    dodajOsobe(tabNazwisko, nazwisko, tabIndeks, indeks, tabImie, imie, i);
        
                    cout<<"ustaw obecnosc: "<<endl;
                    cin>>obecnosc;
                    ustawObecnosc(tabNazwisko, tabObecnosc, nazwisko, obecnosc);
                }
                drukujListe(tabNazwisko, tabObecnosc, tabIndeks, tabImie);
                break;
            }
            
            case 2:
            {
                cout<<"podaj nazwisko osoby do edycji danych: "<<endl;
                cin>>edytuj;
                edytujOsobe(tabNazwisko, tabIndeks,
                 tabImie, tabObecnosc,  edytuj);
                drukujListe(tabNazwisko, tabObecnosc, tabIndeks, tabImie);
                break;
            }
            
            case 3:
            {
                cout<<"podaj nazwisko osoby, ktorej dane chcesz usunac: "<<endl;
                cin>>edytuj;
                usunOsobe( tabNazwisko,  tabIndeks,
                 tabImie, tabObecnosc,  edytuj);
                drukujListe(tabNazwisko, tabObecnosc, tabIndeks, tabImie);
                break;
            }
            
            default: 
            {
                cout<<"wylaczanie programu"<<endl;
                menu=false;
                break;
            }
        }
    }
    
    return 0;
}
