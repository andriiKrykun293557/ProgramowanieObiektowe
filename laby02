#include <iostream>

using namespace std;

const int N=3;

class Osoba
{
    private:
    int klasa_indeks;
    string klasa_imie;
    string klasa_nazwisko;
   
    public:
        Osoba(int id=0, string im="", string nazw="") : klasa_indeks(id), klasa_imie(im), klasa_nazwisko(nazw) {};
    
        void setIndeks(int nowy_indeks) { klasa_indeks = nowy_indeks; };
        void setImie(string nowe_imie) { klasa_imie = nowe_imie; };
        void setNazwisko(string nowe_nazwisko) { klasa_nazwisko = nowe_nazwisko; };
        
        int getIndeks() {return klasa_indeks;}
        string getImie() {return klasa_imie;}
        string getNazwisko() {return klasa_nazwisko;}


};


int znajdzPustke(Osoba *tabOsoba)
{
    for (int i=0; i<N; i++)
    {
        if (tabOsoba[i].getNazwisko()=="")
        {
            return i;
        }
    }
    return -1;
}

int znajdzNazwisko(string klasa_nazwisko, Osoba *tabOsoba)
{
    for (int i=0; i<N; i++)
    {
        if (tabOsoba[i].getNazwisko()==klasa_nazwisko)
        {
            return i;
        }
    }
    return -1;
}

int pustyWskaznik(Osoba **lista)
{
    for (int i=0; i<N; i++)
    {
        if (lista[i]==NULL)
        {
            return i;
        }
    }
    return 0;
}


void dodajOsobe(Osoba *tabOsoba, Osoba nowa_osoba) 
{
    int i=znajdzPustke(tabOsoba);
    if (i!=-1) 
    {
        tabOsoba[i]=nowa_osoba;
    } 
    else 
    {
        cout<<"Brak miejsca w bazie!"<<endl;
    }
}


void ustawObecnosc(Osoba *tabOsoba, Osoba **listaOs, bool *tabObecnosc,string nazwisko, bool obecnosc)
{
    int i = znajdzNazwisko(nazwisko, tabOsoba);
    int j = pustyWskaznik(listaOs);
    listaOs[j]= &tabOsoba[i];
    tabObecnosc[j]= obecnosc;
}

